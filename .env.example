# Camera
CAMERA_INDEX=0
# On Raspberry Pi 5, you may need: CAMERA_INDEX=0 and the CAP_V4L2 backend
# The backend will try CAP_V4L2 on Linux automatically.

# Storage
DB_PATH=./data/presence.db
INSIGHTFACE_HOME=./data/insightface_models

# Pipeline thresholds
DETECTION_CONFIDENCE=0.6
RECOGNITION_CONFIDENCE=0.7
RECOGNITION_THRESHOLD=0.4
RECOGNITION_INTERVAL=1.0
STABILITY_FRAMES=8
LEAVE_DEBOUNCE_SECONDS=5.0
MIN_FACE_PX=80

# Pipeline frame rate
PIPELINE_FPS_IDLE=5        # fps when no video clients connected
PIPELINE_FPS_STREAMING=30  # fps when video WebSocket has active clients

# Video stream (cap on WS send rate; actual rate is limited by pipeline fps)
VIDEO_FPS_CAP=30
VIDEO_JPEG_QUALITY=70

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
