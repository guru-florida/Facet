{
  "name": "presence-client",
  "version": "0.1.0",
  "description": "Presence service hooks and components for React dashboards",
  "type": "module",
  "main": "./dist/presence-client.js",
  "module": "./dist/presence-client.js",
  "types": "./dist/presence-client.d.ts",
  "exports": {
    ".": {
      "import": "./dist/presence-client.js",
      "types": "./dist/presence-client.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist/types",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@mui/icons-material": ">=6",
    "@mui/material": ">=6",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  }
}
